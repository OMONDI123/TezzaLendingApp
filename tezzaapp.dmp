-- Data for Name: ad_department; Type: TABLE DATA; Schema: public; Owner: tezzauser
--

COPY public.ad_department (ad_department_id, ad_client_id, ad_org_id, ammend, approval_date, approvalstage, c_bpartner_id, created, createdby, description, docstatus, documentno, isactive, isapproved, name, processed, processing, reject, rejected_date, updated, updatedby, ad_department_uu, amendment_reason, current_approval_level, reject_reason) FROM stdin;
